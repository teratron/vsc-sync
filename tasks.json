{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sync Settings",
            "type": "shell",
            "command": "${workspaceFolder}/.scripts/Sync.ps1",
            "problemMatcher": [],
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Sync (Startup)",
            "type": "shell",
            "command": "git pull --rebase",
            "problemMatcher": [],
            "runOptions": {
                "runOn": "default"
            },
            "presentation": {
                "reveal": "never",
                "showInExplorer": false,
                "hidden": true
            }
        }
    ]
}